# OPENROUTER_API_KEY: Required for OpenRouter API calls.
OPENROUTER_API_KEY="MY_OPENROUTER_API_KEY"

# OPENROUTER_PRIMARY_MODEL: The first model to try for chat completions.
OPENROUTER_PRIMARY_MODEL="google/gemma-4-31b-it"

# OPENROUTER_FALLBACK_MODELS: Comma-separated fallback model list.
# Add more models here later without changing the code.
OPENROUTER_FALLBACK_MODELS="qwen/qwen3.5-35b-a3b"

# OPENROUTER_BASE_URL: Optional override for the OpenRouter API base URL.
OPENROUTER_BASE_URL="https://openrouter.ai/api/v1"

# OPENROUTER_APP_NAME: Optional title sent to OpenRouter for request attribution.
OPENROUTER_APP_NAME="legal-intake-egov-mcp"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# SERVER_HOST: Defaults to 127.0.0.1 so the app stays local-only unless you
# explicitly expose it.
SERVER_HOST="127.0.0.1"

# APP_ALLOWED_ORIGINS: Comma-separated browser origins allowed to call the API.
# In production, set this to your deployed app origin.
APP_ALLOWED_ORIGINS="http://localhost:3000"

# BASIC_AUTH_*: When exposed publicly, protect the whole app with HTTP Basic Auth.
# Basic auth auto-enables in production when SERVER_HOST is not loopback.
BASIC_AUTH_ENABLED="false"
BASIC_AUTH_USERNAME="change-me"
BASIC_AUTH_PASSWORD="change-me"
BASIC_AUTH_REALM="Legal Intake"

# MCP_HTTP_ENABLED: Disable raw MCP-over-HTTP helper endpoints in production
# unless you explicitly need them.
MCP_HTTP_ENABLED="false"
